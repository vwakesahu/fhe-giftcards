# Buyer wallet private key (needs ETH for gas, USDC for payment)
PRIVATE_KEY=

# Observer wallet private key (needs ETH for bond + gas)
OBSERVER_PRIVATE_KEY=

# Base Sepolia RPC. Default public endpoint is flaky under load — prefer
# Alchemy/Infura/QuickNode for a stable experience.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Underlying USDC address. Circle's Base Sepolia USDC:
#   https://faucet.circle.com — faucet 10 USDC at a time
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Reloadly Sandbox — observer uses these to fulfil gift-card orders.
# Sign up: reloadly.com → toggle Test mode → Developers → API Settings.
# Sandbox has $1000 test balance and returns fake redeem codes.
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=

# Pinata IPFS — stores the AES-encrypted gift card payload.
# Sign up: pinata.cloud → API Keys → New Key.
PINATA_JWT=
PINATA_GATEWAY=gateway.pinata.cloud

# Basescan API key for contract verification (optional).
BASESCAN_API_KEY=
