# ─── Server-only ─────────────────────────────────────────
# Upstream Base Sepolia RPC. Kept server-side so nobody hits your dedicated
# endpoint directly — the /api/rpc route proxies with a simple per-IP rate
# limiter. Use an Alchemy / Infura / QuickNode URL here, not the public one.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Client-exposed (NEXT_PUBLIC_…) ──────────────────────
# Deployed contract addresses on Base Sepolia. Update after running
# `pnpm --filter @sigill/contracts deploy`.
NEXT_PUBLIC_SIGILL_ADDRESS=0xB4ebF18293EC0243c4FC78804A97E14DA6eA87c3
NEXT_PUBLIC_CUSDC_ADDRESS=0x85F912D25D24683b46E8f2e769c7e9693D10444b
NEXT_PUBLIC_USDC_ADDRESS=0xE29D70400026d77a790a8E483168B94D6E36424F

# Single active observer. Shown in the buy wizard alongside 3 "coming soon"
# slots. If you run multiple observers, wire a routing server and delete the
# placeholders in src/lib/contracts.ts.
NEXT_PUBLIC_OBSERVER_ADDRESS=0xc6377415Ee98A7b71161Ee963603eE52fF7750FC

# Pinata gateway used to fetch the AES-encrypted gift-card payload.
NEXT_PUBLIC_PINATA_GATEWAY=gateway.pinata.cloud

# Optional — only needed if you add WalletConnect wallets later.
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
