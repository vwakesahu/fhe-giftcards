# ─── Required ──────────────────────────────────────────
# Private key of the observer EOA (0x-prefixed hex).
OBSERVER_PRIVATE_KEY=0x...

# Upstream Base Sepolia RPC. Use a dedicated endpoint — Alchemy, QuickNode, etc.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Sigill contract (from packages/contracts/deployments/base-sepolia.json).
SIGILL_ADDRESS=0x...
CUSDC_ADDRESS=0x...

# ─── Optional ──────────────────────────────────────────
# Poll interval (milliseconds). Default 10000.
POLL_INTERVAL_MS=10000

# Reloadly sandbox — required. Daemon refuses to run without both.
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=

# Pinata — required for persistent IPFS CIDs. Without PINATA_JWT, fulfilments
# would store ciphertext in an in-memory map that evaporates on restart, so
# buyers could never open the envelope.
PINATA_JWT=
PINATA_GATEWAY=gateway.pinata.cloud
