{
  "name": "sigil",
  "version": "0.1.0",
  "private": true,
  "description": "Sigil — private FHE-backed checkout on Base Sepolia",
  "scripts": {
    "app:dev": "pnpm --filter @sigil/app dev",
    "app:build": "pnpm --filter @sigil/app build",
    "app:start": "pnpm --filter @sigil/app start",
    "landing:dev": "pnpm --filter @sigil/landing dev",
    "landing:build": "pnpm --filter @sigil/landing build",
    "landing:start": "pnpm --filter @sigil/landing start",
    "contracts:compile": "pnpm --filter @sigil/contracts compile",
    "contracts:test": "pnpm --filter @sigil/contracts test",
    "contracts:deploy": "pnpm --filter @sigil/contracts deploy",
    "contracts:observer": "pnpm --filter @sigil/contracts observer"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3"
}
